# ============================================================
# TechParts Ecommerce - Environment Variables Template
# ------------------------------------------------------------
# Copy file này thành .env (cùng folder) rồi điền giá trị thật.
# .env đã được liệt kê trong .gitignore — KHÔNG commit lên Git.
# ============================================================

# ===== Email SMTP (Gmail) =====
APP_MAIL_ENABLED=true
APP_MAIL_FROM=your-email@gmail.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# Gmail App Password (16 ký tự, không phải mật khẩu Gmail thường).
# Tạo tại: https://myaccount.google.com/apppasswords
MAIL_PASSWORD=xxxxxxxxxxxxxxxx
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# ===== Refund =====
APP_REFUND_GOOGLE_FORM_URL=https://forms.gle/your-refund-form-id

# ===== Hỗ trợ =====
APP_SUPPORT_HOTLINE=0901-234-567

# ===== Database (override mặc định nếu cần) =====
# DB_URL=jdbc:mysql://localhost:3306/it_components_ecommerce
# DB_USERNAME=root
# DB_PASSWORD=123456

# ============================================================
# TechParts Ecommerce - Environment Variables Template
# ------------------------------------------------------------
# Copy file này thành .env (cùng folder) rồi điền giá trị thật.
# .env đã được liệt kê trong .gitignore — KHÔNG commit lên Git.
# ============================================================

# ===== Database =====
DB_URL=jdbc:mysql://localhost:3306/it_components_ecommerce?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your-mysql-password

# ===== JWT (>= 32 ký tự ngẫu nhiên — production phải khác dev) =====
# Tạo: openssl rand -hex 32
APP_JWT_SECRET=replace-with-32-byte-random-hex-string

# ===== Tài khoản admin bootstrap (tạo lần đầu) =====
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me-in-production
APP_ADMIN_EMAIL=admin@techparts.local

# ===== CORS =====
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== SePay (cổng thanh toán) =====
# Lấy từ my.sepay.vn → Cấu hình công ty
APP_SEPAY_MERCHANT_ID=
APP_SEPAY_SECRET_KEY=
# API token (tạo tại my.sepay.vn → Cấu hình công ty → Truy cập API → + Add API)
SEPAY_API_TOKEN=
SEPAY_CALLBACK_BASE_URL=http://localhost:8080
SEPAY_POLLING_ENABLED=false

# ===== Email SMTP (Gmail) =====
APP_MAIL_ENABLED=false
APP_MAIL_FROM=your-email@gmail.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# Gmail App Password (16 ký tự, không phải mật khẩu Gmail thường).
# Tạo tại: https://myaccount.google.com/apppasswords
MAIL_PASSWORD=xxxxxxxxxxxxxxxx
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# ===== Web base URL (dùng trong link email gửi cho khách) =====
APP_WEB_BASE_URL=http://localhost:8080

# ===== Hỗ trợ =====
APP_SUPPORT_HOTLINE=1900-1234
